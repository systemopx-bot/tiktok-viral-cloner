# ============ GROQ API (Para análisis de videos con IA barato) ============
# Crear cuenta gratis: https://console.groq.com
# Copiar tu API key de: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ============ FAL.AI API (Para Seedance 2.0) ============
# Opción 1: FAL.AI (más fácil, autorizado por ByteDance)
# Cuenta: https://fal.ai
# Keys: https://fal.ai/dashboard/keys
FAL_API_KEY=your-fal-api-key-here

# Opción 2: BytePlus ModelArk (oficial ByteDance, mejor pricing en volumen)
# Cuenta: https://console.byteplus.com/ark
# Este es el endpoint oficial de ByteDance
BYTEPLUS_ARK_API_KEY=ark-xxxxxxxx

# ============ SERVER CONFIG ============
PORT=3000
NODE_ENV=development

# ============ OPTIONAL: Integración TikTok Shop (para publicación futura) ============
# TIKTOK_SELLER_ID=your-seller-id
# TIKTOK_BUSINESS_ACCESS_TOKEN=your-token
